    "BASE_MODEL = \"google/gemma-3-1b-it\"  # Gemma 3 1B instruction-tuned\n",
    "NUM_EPOCHS = 25          # larger dataset supports longer training\n",
    "PER_DEVICE_TRAIN_BATCH_SIZE = 2   # lower to save VRAM; accum compensates\n",
    "GRADIENT_ACCUMULATION_STEPS = 4   # effective batch = 8; better gradient estimates\n",
    "MAX_INPUT_LENGTH = 128  # p95 prompt ~118 tokens — needs headroom\n",
    "MAX_TARGET_LENGTH = 64   # p95 answer ~65 tokens; 128 was too generous\n",
    "USE_QUICK_CPU_MODE = False # Set to True for faster CPU-based testing, False for full training\n",
    "MAX_TRAIN_SAMPLES = 96 if USE_QUICK_CPU_MODE else None\n",
    "MAX_TEST_SAMPLES = 24 if USE_QUICK_CPU_MODE else None\n",
    "\n",
    "LEARNING_RATE = 2e-5    # more stable with bnb 4-bit + larger adapter\n",
    "WEIGHT_DECAY = 0.01\n",
    "LABEL_SMOOTHING = 0.1   # small smoothing helps generalisation on tiny datasets\n",
    "EARLY_STOPPING_PATIENCE = 6       # give model more room to recover\n",
    "EARLY_STOPPING_THRESHOLD = 0.0\n",
    "\n",
    "LORA_R = 16              # 393 samples supports a bigger adapter\n",
    "LORA_ALPHA = 32         # keep alpha = 2×r\n",
    "LORA_DROPOUT = 0.1       # stronger regularisation\n",
    "LORA_TARGET_MODULES = [\n",
    "    \"q_proj\",\n",
    "    \"k_proj\",\n",
    "    \"v_proj\",\n",
    "    \"o_proj\",\n",
    "    \"gate_proj\",\n",
    "    \"up_proj\",\n",
    "    \"down_proj\",\n",
    "]\n",
    "\n",
    "AUGMENT_PROB = 0.25      # enable augmentation — dataset is large enough now\n",
    "AUGMENT_MAX_OPS = 1\n",
    "AUGMENT_SEED = 42\n",
    "\n",
    "USE_GPU = torch.cuda.is_available()\n",
    "DEVICE = torch.device('cuda' if USE_GPU else 'cpu')\n",
    "# 4-bit quantisation via bitsandbytes — reduces VRAM/RAM significantly.\n",
    "# Requires bitsandbytes installed. Safe to leave True on CPU (falls back gracefully).\n",
    "USE_4BIT = USE_GPU  # set False to disable\n",
    "USE_BF16 = False\n",
    "if USE_GPU and hasattr(torch.cuda, 'is_bf16_supported'):\n",
    "    USE_BF16 = torch.cuda.is_bf16_supported()\n",
    "USE_FP16 = USE_GPU and not USE_BF16\n",
    "USE_GRADIENT_CHECKPOINTING = False\n",
    "USE_TF32 = USE_GPU\n",
    "if USE_TF32:\n",
    "    torch.backends.cuda.matmul.allow_tf32 = True\n",
    "    torch.backends.cudnn.allow_tf32 = True\n",
    "if hasattr(torch, 'set_float32_matmul_precision'):\n",
    "    torch.set_float32_matmul_precision('high')\n",
    "\n",
    "GEN_DO_SAMPLE = False\n",
    "GEN_NUM_BEAMS = 4        # 8 beams is very slow on CPU; 4 is the sweet spot\n",
    "GEN_TEMPERATURE = 0.7\n",
    "GEN_TOP_P = 0.9\n",
    "GEN_TOP_K = 50\n",
    "GEN_NO_REPEAT_NGRAM_SIZE = 4\n",
    "GEN_EARLY_STOPPING = True\n",
    "GEN_LENGTH_PENALTY = 1.2\n",
    "GEN_REPETITION_PENALTY = 1.15\n",
    "GEN_MIN_NEW_TOKENS = 4   # 16 forces padding on genuinely short answers\n",
    "\n",
    "generation_config = {\n",
    "    'do_sample': GEN_DO_SAMPLE,\n",
    "    'num_beams': GEN_NUM_BEAMS,\n",
    "    'temperature': GEN_TEMPERATURE,\n",
    "    'top_p': GEN_TOP_P,\n",
    "    'top_k': GEN_TOP_K,\n",
    "    'no_repeat_ngram_size': GEN_NO_REPEAT_NGRAM_SIZE,\n",
    "    'early_stopping': GEN_EARLY_STOPPING,\n",
    "    'length_penalty': GEN_LENGTH_PENALTY,\n",
    "    'repetition_penalty': GEN_REPETITION_PENALTY,\n",
    "    'min_new_tokens': GEN_MIN_NEW_TOKENS,\n",
    "}\n",
    "\n",
    "RUN_POST_TRAIN_EVAL = True\n",
    "\n",
    "print('Base model:', BASE_MODEL)\n",
    "print('Quick CPU mode:', USE_QUICK_CPU_MODE)\n",
    "print('Max train samples:', MAX_TRAIN_SAMPLES)\n",
    "print('Max test samples:', MAX_TEST_SAMPLES)\n",
    "print('Training device:', DEVICE)\n",
    "print('Learning rate:', LEARNING_RATE)\n",
    "print('Weight decay:', WEIGHT_DECAY)\n",
    "print('Label smoothing:', LABEL_SMOOTHING)\n",
    "print('Early stopping patience:', EARLY_STOPPING_PATIENCE)\n",
    "print('BF16 enabled:', USE_BF16)\n",
    "print('FP16 enabled:', USE_FP16)\n",
    "print('LoRA r:', LORA_R)\n",
    "print('LoRA alpha:', LORA_ALPHA)\n",
    "print('LoRA targets:', LORA_TARGET_MODULES)\n",
    "print('Generation sampling:', GEN_DO_SAMPLE)\n",
    "print('4-bit quantisation:', USE_4BIT)\n"
   ]
  },
