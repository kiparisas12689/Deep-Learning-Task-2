   "source": [
    "tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL, use_fast=True)\n",
    "\n",
    "# Gemma 3 tokenizer already has a pad token, but guard just in case\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.add_special_tokens({'pad_token': '<pad>'})\n",
    "\n",
    "# Optional 4-bit quantisation — reduces memory footprint by ~4×\n",
    "bnb_config = None\n",
    "if USE_4BIT:\n",
    "    try:\n",
    "        bnb_config = BitsAndBytesConfig(\n",
    "            load_in_4bit=True,\n",
    "            bnb_4bit_quant_type=\"nf4\",\n",
    "            bnb_4bit_compute_dtype=torch.bfloat16 if USE_BF16 else torch.float16,\n",
    "            bnb_4bit_use_double_quant=True,\n",
    "        )\n",
    "        print(\"4-bit quantisation enabled.\")\n",
    "    except Exception as e:\n",
    "        print(f\"bitsandbytes not available, falling back to full precision: {e}\")\n",
    "        bnb_config = None\n",
    "\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    BASE_MODEL,\n",
    "    quantization_config=bnb_config,\n",
    "    torch_dtype=torch.bfloat16 if USE_BF16 else (torch.float16 if USE_FP16 else torch.float32),\n",
    "    device_map=\"auto\" if USE_GPU else None,\n",
    "    attn_implementation=\"eager\",   # Gemma 3 requires eager attention (no flash-attn needed)\n",
    ")\n",
    "model.config.pad_token_id = tokenizer.pad_token_id\n",
    "\n",
    "peft_config = LoraConfig(\n",
    "    task_type=TaskType.CAUSAL_LM,\n",
    "    r=LORA_R,\n",
    "    lora_alpha=LORA_ALPHA,\n",
    "    lora_dropout=LORA_DROPOUT,\n",
    "    target_modules=LORA_TARGET_MODULES,\n",
    ")\n",
    "\n",
    "model = get_peft_model(model, peft_config)\n",
    "if USE_GRADIENT_CHECKPOINTING:\n",
    "    # enable_input_require_grads() is required when using gradient checkpointing\n",
    "    # with PEFT/LoRA — without it the backward pass raises:\n",
    "    #   \"element 0 of tensors does not require grad and does not have a grad_fn\"\n",
    "    model.enable_input_require_grads()\n",
    "    model.gradient_checkpointing_enable()\n",
    "    model.config.use_cache = False\n",
    "model.print_trainable_parameters()\n",
    "# Only move when not using device_map=\"auto\" (quantised models are\n",
    "# already placed by HF on the right device)\n",
    "if bnb_config is None and not USE_GPU:\n",
    "    model.to(DEVICE)\n",
    "\n",
    "\n",
    "def preprocess_example(example):\n",
    "  
    "    messages = [\n",
    "        {\"role\": \"user\", \"content\": f\"{PROMPT_PREFIX}\\n\\n{example['informal_text']}\"},\n",
    "    ]\n",
    "    prompt = tokenizer.apply_chat_template(\n",
    "        messages,\n",
    "        tokenize=False,\n",
    "        add_generation_prompt=True,  # appends the <start_of_turn>model token\n",
    "    )\n",
    "    answer = example[\"formal_text\"]\n",
    "\n",
    "    prompt_ids = tokenizer(prompt, add_special_tokens=False)[\"input_ids\"]\n",
    "    answer_ids = tokenizer(answer, add_special_tokens=False)[\"input_ids\"]\n",
    "\n",
    "    # Append <end_of_turn> (Gemma 3's turn separator) then EOS so the model\n",
    "    # learns exactly where the answer ends — matching its pretraining format.\n",
    "    end_turn_ids = tokenizer.encode(\"<end_of_turn>\", add_special_tokens=False)\n",
    "    eos_id = tokenizer.eos_token_id\n",
    "    answer_ids = answer_ids + end_turn_ids + ([eos_id] if eos_id is not None else [])\n",
    "\n",
    "    input_ids = prompt_ids + answer_ids\n",
    "\n",
    "    labels = [-100] * len(prompt_ids) + answer_ids\n",
    "\n",
    "    # truncate if too long\n",
    "    input_ids = input_ids[:MAX_INPUT_LENGTH + MAX_TARGET_LENGTH]\n",
    "    labels = labels[:MAX_INPUT_LENGTH + MAX_TARGET_LENGTH]\n",
    "\n",
    "    return {\n",
    "        \"input_ids\": input_ids,\n",
    "        \"labels\": labels,\n",
    "        \"attention_mask\": [1] * len(input_ids),\n",
    "    }\n",
    "\n",
    "\n",
    "train_dataset = Dataset.from_list(augmented_train_rows)\n",
    "eval_dataset = Dataset.from_list(working_test_rows)\n",
    "train_tokenized = train_dataset.map(preprocess_example, remove_columns=train_dataset.column_names)\n",
    "eval_tokenized = eval_dataset.map(preprocess_example, remove_columns=eval_dataset.column_names)\n",
    "\n",
    "import torch\n",
    "\n",
    "def data_collator(features):\n",
    "    max_len = max(len(f[\"input_ids\"]) for f in features)\n",
    "\n",
    "    input_ids = []\n",
    "    attention_mask = []\n",
    "    labels = []\n",
    "\n",
    "    for f in features:\n",
    "        pad_len = max_len - len(f[\"input_ids\"])\n",
    "\n",
    "        input_ids.append(f[\"input_ids\"] + [tokenizer.pad_token_id] * pad_len)\n",
    "        attention_mask.append(f[\"attention_mask\"] + [0] * pad_len)\n",
    "        labels.append(f[\"labels\"] + [-100] * pad_len)\n",
    "\n",
    "    return {\n",
    "        \"input_ids\": torch.tensor(input_ids, dtype=torch.long),\n",
    "        \"attention_mask\": torch.tensor(attention_mask, dtype=torch.long),\n",
    "        \"labels\": torch.tensor(labels, dtype=torch.long),\n",
    "    }\n",
    "\n",
    "training_args = TrainingArguments(\n",
    "    output_dir=str(model_output_dir),\n",
    "    num_train_epochs=NUM_EPOCHS,\n",
    "    learning_rate=LEARNING_RATE,\n",
    "    per_device_train_batch_size=PER_DEVICE_TRAIN_BATCH_SIZE,\n",
    "    gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,\n",
    "    eval_strategy='epoch',\n",
    "    logging_strategy='epoch',\n",
    "    save_strategy='epoch',\n",
    "    save_total_limit=2,\n",
    "    load_best_model_at_end=True,\n",
    "    metric_for_best_model='eval_loss',\n",
    "    greater_is_better=False,\n",
    "    per_device_eval_batch_size=4,\n",
    "    report_to='none',\n",
    "    remove_unused_columns=False,\n",
    "    disable_tqdm=True,\n",
    "    # When 4-bit quant is active, precision is controlled by BitsAndBytesConfig\n",
    "    # — setting fp16/bf16 on top causes conflicts and NaN loss on some setups.\n",
    "    fp16=USE_FP16 and bnb_config is None,\n",
    "    bf16=USE_BF16 and bnb_config is None,\n",
    "    gradient_checkpointing=USE_GRADIENT_CHECKPOINTING,\n",
    "    dataloader_pin_memory=USE_GPU,\n",
    "    dataloader_num_workers=0 if os.name == 'nt' else (4 if USE_GPU else 0),\n",
    "    label_smoothing_factor=LABEL_SMOOTHING,\n",
    "    weight_decay=WEIGHT_DECAY,\n",
    "    warmup_ratio=0.1,       # ramp LR over first 10% of steps — prevents the\n",
    "                            # large epoch-1 update that makes eval loss look\n",
    " 
    "    eval_delay=3,          
    "                           
    ")\n",
    "\n",
    "trainer = Trainer(\n",
    "    model=model,\n",
    "    args=training_args,\n",
    "    train_dataset=train_tokenized,\n",
    "    eval_dataset=eval_tokenized,\n",
    "    data_collator=data_collator,\n",
    "    callbacks=[\n",
    "        NotebookProgressCallback(),\n",
    "        EarlyStoppingCallback(\n",
    "            early_stopping_patience=EARLY_STOPPING_PATIENCE,\n",
    "            early_stopping_threshold=EARLY_STOPPING_THRESHOLD,\n",
    "        ),\n",
    "    ],\n",
    ")\n",
    "\n",
    "trainer.train()\n",
    "trainer.save_model(str(model_output_dir))\n",
    "tokenizer.save_pretrained(str(model_output_dir))\n",
    "\n",
    "print('Saved model to:', model_output_dir)\n"
   ]
  },
